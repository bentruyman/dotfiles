#!/usr/bin/env bun

import { existsSync, mkdirSync } from "fs";
import { homedir } from "os";
import { dirname, join } from "path";

const SETTINGS_PATH = join(homedir(), ".claude", "settings.json");

const NOTIFICATION_HOOKS = [
  {
    matcher: "permission_prompt",
    hooks: [{ type: "command", command: "~/.bin/claude-notify permission_prompt" }],
  },
  {
    matcher: "idle_prompt",
    hooks: [{ type: "command", command: "~/.bin/claude-notify idle_prompt" }],
  },
  {
    matcher: "auth_success",
    hooks: [{ type: "command", command: "~/.bin/claude-notify auth_success" }],
  },
  {
    matcher: "elicitation_dialog",
    hooks: [{ type: "command", command: "~/.bin/claude-notify elicitation_dialog" }],
  },
];

const STOP_HOOKS = [
  {
    hooks: [{ type: "command", command: "~/.bin/claude-notify stop" }],
  },
];

async function main() {
  let settings: Record<string, unknown> = {};

  if (existsSync(SETTINGS_PATH)) {
    const content = await Bun.file(SETTINGS_PATH).text();
    settings = JSON.parse(content);
  } else {
    mkdirSync(dirname(SETTINGS_PATH), { recursive: true });
  }

  settings.hooks ??= {};
  const hooks = settings.hooks as Record<string, unknown>;
  hooks.Notification = NOTIFICATION_HOOKS;
  hooks.Stop = STOP_HOOKS;

  await Bun.write(SETTINGS_PATH, JSON.stringify(settings, null, 2) + "\n");

  console.log(`Updated ${SETTINGS_PATH}`);
}

main().catch((err) => {
  console.error("Error:", err.message);
  process.exit(1);
});
