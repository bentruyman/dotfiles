# vim: ft=gitconfig
[core]
  excludesfile = ~/.gitignore_global
  pager = delta
  ignorecase = false

[alias]
  checkpoint = commit --no-verify -m 'chore: checkpoint'
  down = commit --amend --no-edit

[branch]
  autosetuprebase = always

[color]
  ui = auto

[commit]
  gpgsign = true

[delta]
  navigate = true

[diff]
  colorMoved = default
  renames = copies

[filter "lfs"]
  clean = git-lfs clean -- %f
  process = git-lfs filter-process
  required = true
  smudge = git-lfs smudge -- %f

[include]
  path = ~/.gitconfig_user

[includeIf "hasconfig:remote.*.url:**.apple.com:**/**"]
  path = ~/.gitconfig_work

[init]
  defaultbranch = main

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictstyle = diff3
  ff = only

[pull]
  ff = only

[push]
  autoSetupRemote = true
  default = current
  followTags = true
  setupAutoRemote = true
