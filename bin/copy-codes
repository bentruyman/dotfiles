#!/usr/bin/env fish

# Function: copy-code
# Description:
#   Outputs the contents of matching files in a Git repository, excluding ignored and binary files.
#   Each file's content is wrapped with separators and includes the filename as a header.
#
# Usage:
#   copy-code [glob_pattern] [repo_path]
#
# Arguments:
#   glob_pattern (optional): Glob to match files (e.g., "*.cs"). Defaults to "*" if not provided.
#   repo_path (optional): Path to the Git repository. Defaults to the current directory.

# Set default values
set glob "*"
set repo (pwd)

# Parse arguments
set argc (count $argv)

if test $argc -ge 1
    set first_arg $argv[1]
    # Check if the first argument is a directory
    if test -d "$first_arg"
        set repo $first_arg
    else
        set glob $first_arg
    end
end

if test $argc -ge 2
    set second_arg $argv[2]
    if test -d "$second_arg"
        set repo $second_arg
    else
        echo "Error: '$second_arg' is not a valid directory."
        exit 1
    end
end

# Verify that the specified repository is a Git repository
if not test -d "$repo/.git"
    echo "Error: '$repo' is not a Git repository."
    exit 1
end

# Navigate to the repository directory
pushd $repo > /dev/null

# Retrieve list of non-ignored files matching the glob pattern
# Using git ls-files to list tracked and untracked files, excluding ignored
set all_files (git ls-files --cached --others --exclude-standard -- "$glob")

# Check if any files matched
if test (count $all_files) -eq 0
    echo "No files matched the pattern '$glob' in repository '$repo'."
    popd > /dev/null
    exit 0
end

# Retrieve list of text files by filtering out binary files using git grep
# git grep -Il . lists all files containing at least one printable character line (i.e., text files)
set text_files (git grep -Il . -- $all_files)

# Check if any text files matched
if test (count $text_files) -eq 0
    echo "No text files matched the pattern '$glob' in repository '$repo'."
    popd > /dev/null
    exit 0
end

# Iterate through each text file and output its contents with headers
for file in $text_files
    echo "## $file"
    echo "```"
    cat "$file"
    echo "```"
    echo
end

# Return to the original directory
popd > /dev/null
